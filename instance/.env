# environment settings
XF_INSTANCE=xf
XF_CONTEXTS=development

# general settings
XF_TITLE="XenForo [${XF_INSTANCE}]"
XF_EMAIL=example@example.com
XF_CONTACT_EMAIL=${XF_EMAIL}
XF_COOKIE_PREFIX=${XF_INSTANCE}_

# database settings
XF_DB_USER=xf
XF_DB_PASSWORD=password
XF_DB_DATABASE=xf
XF_DB_REPLICATION_USER=xf_replication
XF_DB_REPLICATION_PASSWORD=replication_password
XF_MSSQL_PASSWORD=Password123

# email settings
XF_MAIL_ENABLE=0
XF_MAIL_HOST=
XF_MAIL_PORT=
XF_MAIL_USERNAME=
XF_MAIL_PASSWORD=
XF_MAIL_SSL=0

# cache settings
XF_CACHE_SESSIONS=1
XF_CACHE_PAGES=0

# search settings
XF_XFES_SEARCH_USER=elastic
XF_XFES_SEARCH_PASSWORD=password

# additional settings
XF_IMAGICK_ENABLE=0
XF_XFMG_FFMPEG_ENABLE=0

# development settings
XF_DEBUG=1
XF_DEVELOPMENT=1
XF_ADMIN_HUE_SHIFT=90
