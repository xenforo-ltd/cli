#!/usr/bin/env bash

#   __  _______   ____   ___   ____ _  _______ ____
#   \ \/ /  ___| |  _ \ / _ \ / ___| |/ / ____|  _ \
#    \  /| |_    | | | | | | | |   | ' /|  _| | |_) |
#    /  \|  _|   | |_| | |_| | |___| . \| |___|  _ <
#   /_/\_\_|     |____/ \___/ \____|_|\_\_____|_| \_\
#
# A management utility for Docker-powered XenForo installations.
#
# Copyright (c) 2025 XenForo Ltd.
# https://github.com/xenforo-ltd/docker

# print command traces when $TRACE is set
if [[ -n "${TRACE}" ]]; then
	set -o xtrace
fi

# fail fast and set sane defaults
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

# set globals
XF_SELF="$(basename "${BASH_SOURCE[0]}")"
readonly XF_SELF
XF_SELF_DIR="$(dirname "${BASH_SOURCE[0]}")"
readonly XF_SELF_DIR
XF_DOCKER_DIR="$(dirname "${XF_SELF_DIR}")"
readonly XF_DOCKER_DIR

# xf::get_xf_dir()
#
# Usage:
#   xf::get_xf_dir
#
# Description:
#   Traverses up the current working directory to find and print a XenForo root
#   directory. If one cannot be found, the $XF_DIR environment variable is
#   checked and printed. An error is returned if no valid XenForo root directory
#   can be found.
xf::get_xf_dir()
{
	local directory
	directory="$(pwd)"
	while [[ "${directory}" != "/" ]]; do
		if [[ -f "${directory}/src/XF.php" ]]; then
			printf "%s" "${directory}"
			return
		fi

		directory="$(dirname "${directory}")"
	done

	if [[ -f "/src/XF.php" ]]; then
		printf "/"
		return
	fi

	if [[ -z "${XF_DIR:-}" || ! -f "${XF_DIR}/src/XF.php" ]]; then
		printf "You are not within a XenForo directory and no valid " >&2
		printf "\$XF_DIR was set.\n" >&2
		return 1
	fi

	printf "%s" "${XF_DIR}"
}

# xf::check_requirements()
#
# Usage:
#   xf::check_requirements
#
# Description:
#   Checks if the requirements to install and run the environment are met. An
#   error is returned if the requirements are not met.
xf::check_requirements()
{
	if [[ ! -x "$(command -v docker)" ]]; then
		printf "Docker does not appear to be installed.\n" >&2
		return 1
	fi

	if ! docker compose &>/dev/null; then
		printf "Docker Compose does not appear to be installed.\n" >&2
		return 1
	fi
}

# xf::check_environment()
#
# Usage:
#   xf::check_environment
#
# Description:
#   Checks if the environment is valid. An error is returned if the environment
#   is not valid.
xf::check_environment()
{
	local xf_dir
	xf_dir="$(xf::get_xf_dir)"

	if [[ ! -f "${xf_dir}/compose.yaml" ]]; then
		printf "You do not appear to be in a valid environment. " >&2
		printf "Did you forget to run %s init?\n" "${XF_SELF}" >&2
		return 1
	fi
}

# xf::get_compose_files()
#
# Usage:
#   xf::get_compose_files
#
# Description:
#   Parses the $XF_ENVIRONMENTS environment variable, or the .env file of the
#   XenForo installation if the environment variable is not set, to discover
#   and print the desired Compose file arguments. An error is returned if the
#   settings are not valid.
xf::get_compose_files()
{
	local xf_dir
	xf_dir="$(xf::get_xf_dir)"

	local files=("--file" "${xf_dir}/compose.yaml")

	local environments="${XF_ENVIRONMENTS:-}"
	if [[ -z "${environments}" && -f "${xf_dir}/.env" ]]; then
		environments="$(sed -n 's/^XF_ENVIRONMENTS=\([a-z:]*\)$/\1/p' "${xf_dir}/.env")"
	fi

	IFS=":" read -ra environments <<<"${environments}"

	for environment in "${environments[@]}"; do
		local file="compose.${environment}.yaml"
		if [[ ! -f "${xf_dir}/${file}" ]]; then
			printf "The %s file does not exist. " "${file}" >&2
			printf "Check your \$XF_ENVIRONMENT settings.\n" >&2
			return 1
		fi

		files+=("--file" "${xf_dir}/${file}")
	done

	if [[ -f "${xf_dir}/compose.override.yaml" ]]; then
		files+=("--file" "${xf_dir}/compose.override.yaml")
	fi

	printf "%s " "${files[@]}"
}

# xf::help()
#
# Usage:
#   xf::help
#
# Description:
# 	Prints the help information.
xf::help()
{
	cat <<EOF
  __  _______   ____   ___   ____ _  _______ ____
  \ \/ /  ___| |  _ \ / _ \ / ___| |/ / ____|  _ \\
   \  /| |_    | | | | | | | |   | ' /|  _| | |_) |
   /  \|  _|   | |_| | |_| | |___| . \| |___|  _ <
  /_/\_\_|     |____/ \___/ \____|_|\_\_____|_| \_\\

A management utility for Docker-powered XenForo installations.

Usage:
  ${XF_SELF} init
  ${XF_SELF} up
  ${XF_SELF} down
  ${XF_SELF} restart
  ${XF_SELF} kill
  ${XF_SELF} build
  ${XF_SELF} pull
  ${XF_SELF} ps
  ${XF_SELF} logs [<options>] [<arguments>]
  ${XF_SELF} run [<options>] <arguments>
  ${XF_SELF} compose [<options>] [<arguments>]
  ${XF_SELF} composer [<options>] [<arguments>]
  ${XF_SELF} php [<options>] [<arguments>]
  ${XF_SELF} php-debug [<options>] [<arguments>]
  ${XF_SELF} debug [<command>] [<options>] [<arguments>]
  ${XF_SELF} [<command>] [<options>] [<arguments>]
EOF
}

# xf::init()
#
# Usage:
#   xf::init
#
# Description:
#   Copies the necessary files into the XenForo installation. The base files
#   overwrite any existing files. The default files are copied with the
#   '.default' extension appended if they already exist in the XenForo
#   installation and differ from the default contents.
xf::init()
{
	xf::check_requirements

	local xf_dir
	xf_dir="$(xf::get_xf_dir)"

	local -r base_files=(
		".docker/nginx.conf"
		"src/config.docker.php"
		"Dockerfile"
		"compose.cache.yaml"
		"compose.development.yaml"
		"compose.mssql.yaml"
		"compose.postgres.yaml"
		"compose.replication.yaml"
		"compose.search.yaml"
		"compose.yaml"
	)
	local -r default_files=(
		".dockerignore"
		".env"
	)

	for file in "${base_files[@]}"; do
		local source_file="${XF_DOCKER_DIR}/instance/${file}"
		local target_file="${xf_dir}/${file}"

		local target_directory
		target_directory="$(dirname "${target_file}")"
		mkdir -p "${target_directory}"

		cp "${source_file}" "${target_file}"
	done

	for file in "${default_files[@]}"; do
		local source_file="${XF_DOCKER_DIR}/instance/${file}"
		local target_file="${xf_dir}/${file}"

		local target_directory
		target_directory="$(dirname "${target_file}")"
		mkdir -p "${target_directory}"

		if [[ ! -f "${target_file}" ]]; then
			cp "${source_file}" "${target_file}"
		elif ! cmp -s "${source_file}" "${target_file}"; then
			cp "${source_file}" "${target_file}.default"
			printf "The default %s file was copied to %s for reference.\n" \
				"${file}" \
				"${file}.default"
		fi
	done

	printf "The environment has been initialized (%s).\n" "${xf_dir}"
}

# xf::compose()
#
# Usage:
#   xf::compose [<command>] [<options>] [<arguments>]
#
# Description:
#   Passes commands, options, and arguments to Docker Compose.
xf::compose()
{
	xf::check_environment

	local files
	compose_files="$(xf::get_compose_files)"
	IFS=" " read -ra compose_files <<<"${compose_files}"

	docker compose "${compose_files[@]}" "$@"
}

# xf::main()
#
# Usage:
#   xf::main [<command>] [<options>] [<arguments>]
#
# Description:
# 	Dispatches commands. If no command is given, or the command is -h or --help,
# 	the help information is printed.
xf::main()
{
	local -r command="${1:-}"
	if [[ -n "${command}" ]]; then
		shift
	fi

	case "${command}" in
		"" | -h | --help)
			xf::help
			;;
		init)
			xf::init
			;;
		up)
			xf::compose up --detach
			;;
		down)
			xf::compose down
			;;
		restart)
			xf::compose restart
			;;
		kill)
			xf::compose kill
			;;
		build)
			xf::compose build --pull
			;;
		pull)
			xf::compose pull --ignore-buildable
			;;
		ps)
			xf::compose ps --services
			;;
		logs)
			xf::compose logs "$@"
			;;
		run)
			xf::compose run --rm "$@"
			;;
		compose)
			xf::compose "$@"
			;;
		composer)
			xf::compose run --rm xf composer "$@"
			;;
		php)
			xf::compose run --rm xf php "$@"
			;;
		php-debug)
			xf::compose run --rm --env XDEBUG_SESSION=1 xf php "$@"
			;;
		debug)
			xf::compose run --rm --env XDEBUG_SESSION=1 xf php cmd.php "$@"
			;;
		*)
			xf::compose run --rm xf php cmd.php "${command}" "$@"
			;;
	esac
}

# run xf::main if this script is called interactively
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
	xf::main "$@"
fi
