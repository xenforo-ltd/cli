# environment settings
XF_PORT=8080
XF_ENVIRONMENTS=development

# general settings
XF_TITLE=XenForo
XF_EMAIL=example@example.com
XF_CONTACT_EMAIL=${XF_EMAIL}
XF_COOKIE_PREFIX=xf_

# database settings
XF_DB_HOST=db
XF_DB_USER=xf
XF_DB_PASSWORD=password
XF_DB_DATABASE=xf

# email settings
XF_ENABLE_MAIL=0
XF_MAIL_HOST=
XF_MAIL_PORT=
XF_MAIL_USERNAME=
XF_MAIL_PASSWORD=
XF_MAIL_ENCRYPT=

# cache settings
XF_ENABLE_CACHE=0
XF_CACHE_SESSIONS=0
XF_CACHE_PAGES=0
XF_CACHE_HOST=cache

# additional settings
XF_ENABLE_IMAGICK=0
XF_ENABLE_XFMG_FFMPEG=1
XF_XFES_SEARCH_HOST=search

# development settings
XF_DEBUG=1
XF_DEVELOPMENT=1
XF_ADMIN_HUE_SHIFT=90

# php settings
PHP_INSTALL_FFMPEG=${XF_ENABLE_XFMG_FFMPEG}
PHP_BUILD_IMAGICK=${XF_ENABLE_IMAGICK}
PHP_BUILD_REDIS=${XF_ENABLE_CACHE}
PHP_BUILD_PGSQL=0
